---
/**
 * Simple footer with back link for sub-pages
 */
---

<footer class="footer">
  <div class="container">
    <p class="footer-text">
      <a href="/">Back to home</a>
    </p>
  </div>
</footer>

<style>
  .footer-text {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin: 0;
  }

  .footer-text a {
    color: var(--color-accent-primary);
    text-decoration: none;
  }

  .footer-text a:hover {
    text-decoration: underline;
  }
</style>
